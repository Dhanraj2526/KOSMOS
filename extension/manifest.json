{
  "manifest_version": 3,
  "name": "KOSMOS Secure Sidepanel",
  "version": "1.2",
  "description": "Securely upload and manage your decentralized assets on the Sepolia blockchain.",
  "permissions": ["sidePanel", "activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open KOSMOS Sidebar"
  },
  "side_panel": {
    "default_path": "popup.html"
  }
}
